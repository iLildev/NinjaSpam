# ============================================================
#  Telegram Group Management Bot — Environment Configuration
#  Copy this file to '.env' and fill in your credentials.
#  NEVER commit '.env' to version control.
# ============================================================

# ----- Core Telegram Settings -----
# Obtain your bot token from @BotFather on Telegram.
BOT_TOKEN=your_bot_token_here

# The numeric Telegram user ID(s) of the bot owner(s).
# Comma-separated for multiple owners, e.g.: 123456789,987654321
OWNER_IDS=123456789

# ----- Database Settings -----
# Full SQLAlchemy-compatible connection string.
# PostgreSQL (recommended for production):
#   postgresql+asyncpg://user:password@host:5432/dbname
# SQLite (for local development only):
#   sqlite+aiosqlite:///./tgbot.db
DATABASE_URL=sqlite+aiosqlite:///./tgbot.db

# ----- Optional: Logging -----
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Path to the log file. Leave blank to log to stdout only.
LOG_FILE=logs/bot.log

# ----- Optional: Bayesian Spam Filter -----
# Minimum number of messages required before the Bayes classifier
# will make a classification decision. Below this threshold the
# classifier abstains and defers to the regex filter.
BAYES_MIN_CORPUS_SIZE=200

# Spam probability threshold (0.0 – 1.0). Messages whose computed
# spam probability exceeds this value are flagged as spam.
BAYES_SPAM_THRESHOLD=0.90

# ----- Optional: CAPTCHA Settings -----
# Time (in seconds) a new member has to solve the CAPTCHA before
# being kicked from the group.
CAPTCHA_TIMEOUT_SECONDS=120

# ----- Optional: Access Control -----
# Comma-separated Telegram user IDs of sudo users (can run owner commands).
SUDO_USERS=

# Comma-separated Telegram user IDs of support users (read-only elevated access).
SUPPORT_USERS=

# When True, globally banned users are kicked on every message they send,
# not only when they join a group. Set to False for join-only enforcement.
STRICT_GBAN=False

# ----- Optional: Rate Limiting -----
# Maximum number of messages a single user may send per minute
# across any rate-limited handler before being silently ignored.
RATE_LIMIT_MESSAGES_PER_MINUTE=30

# ----- Optional: SpamWatch -----
# API token from https://spamwat.ch — leave blank to disable SpamWatch integration.
SPAMWATCH_API_KEY=

# ----- Optional: CAS (Combot Anti-Spam) -----
# CAS API endpoint — default is the public CAS API.
CAS_API_URL=https://api.cas.chat/check

# ----- Optional: RSS Feed Poller -----
# How often (seconds) to poll subscribed RSS feeds for new entries.
RSS_POLL_INTERVAL_SECONDS=300

# Maximum new entries per feed per poll cycle (prevents spam on first sub).
RSS_MAX_ENTRIES_PER_CYCLE=5

# ----- Optional: Scheduler -----
# Minimum scheduling lead time in seconds (prevent scheduling in the past).
SCHEDULER_MIN_LEAD_SECONDS=30

# ----- Optional: Appeal System -----
# Number of days after a ban that a user may submit an appeal.
APPEAL_WINDOW_DAYS=30

# ----- Optional: Night Mode -----
# Default timezone for night mode when none is set per-chat.
NIGHTMODE_DEFAULT_TZ=UTC

# ----- Optional: Adaptive CAPTCHA -----
# Risk score threshold above which adaptive CAPTCHA is triggered.
ADAPTIVE_CAPTCHA_RISK_THRESHOLD=0.6

# ----- Optional: AntiRaid -----
# Default action for detected raiders: kick | ban | mute
ANTIRAID_DEFAULT_ACTION=kick

# ----- Optional: Broadcast -----
# Interval (seconds) between broadcast messages to avoid Telegram flood limits.
BROADCAST_DELAY_SECONDS=0.05
